    "react-helmet-async": "1.3.0",
    "react-icons": "4.4.0",
    "react-router-dom": "6.3.0",
    "react-scroll": "1.8.7"
  },
  "devDependencies": {
    "@types/ejs": "3.1.1",
    "@types/gtag.js": "0.0.10",
    "@types/node": "17.0.45",
